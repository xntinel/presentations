---
// Reusable reveal.js shell: base styles, fonts, themes, and the deck control.
// Any deck (MDX or MD) renders inside the <slot>. The theme is applied via
// data-theme; all theme blocks load once from themes.css, so switching/reusing
// a theme is just changing the attribute. The floating control is DeckNav.astro
// and the client init lives in src/scripts/deck-init.ts.
import 'reveal.js/reveal.css';
import '@fontsource-variable/manrope';
import '@fontsource-variable/quicksand';
import '@fontsource-variable/jetbrains-mono';
import '@themes/themes.css';
import type { ThemeName } from '@themes/registry';
import DeckNav from '@components/DeckNav.astro';

interface Props {
  title: string;
  theme?: ThemeName;
}

const { title, theme = 'steel-light' } = Astro.props;

// Home/gallery with the correct base (guarantees a trailing slash).
const homeHref = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="es" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link
      rel="icon"
      href={`${import.meta.env.BASE_URL}/favicon.svg`}
      type="image/svg+xml"
    />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <div class="reveal" data-theme={theme}>
      <div class="slides">
        <slot />
      </div>
    </div>

    <DeckNav homeHref={homeHref} />

    <script>
      import '@scripts/deck-init';
    </script>
  </body>
</html>
