---
// Shell reutilizable de reveal.js: estilos base, fuentes, temas y el script de
// inicializacion. Cualquier deck (MDX o MD) se renderiza dentro del <slot>.
// El tema se aplica via data-theme; todos los bloques de tema cargan una vez
// desde themes.css, asi que cambiar/reusar tema es solo cambiar el atributo.
import 'reveal.js/reveal.css';
import 'augmented-ui/augmented-ui.min.css';
import '@fontsource-variable/manrope';
import '@fontsource-variable/quicksand';
import '@fontsource-variable/jetbrains-mono';
import '../themes/themes.css';

interface Props {
  title: string;
  theme?: string;
}

const { title, theme = 'steel-light' } = Astro.props;

// Home/galeria con el base correcto (garantiza barra final).
const homeHref = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="es" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.svg`} type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <div class="reveal" data-theme={theme}>
      <div class="slides">
        <slot />
      </div>
    </div>

    {/* Control del deck: el boton glass (estilo mac) anclado arriba-derecha es por
        defecto PANTALLA COMPLETA (click = toggle, tecla F). Al pasar el cursor se
        expande hacia la IZQUIERDA y revela mas opciones (Inicio). Vive fuera de
        .reveal para que reveal no lo escale; hereda los tokens del tema desde
        :root[data-theme]. */}
    <nav class="deck-nav" id="deck-nav" aria-label="Controles de la presentacion">
      <a
        class="deck-nav__btn deck-nav__item"
        href={homeHref}
        aria-label="Inicio"
        title="Inicio"
        style="--i: 0"
      >
        <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9.6 12 3l9 6.6V20a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1z" />
        </svg>
      </a>
      <button
        id="fs-toggle"
        class="deck-nav__btn deck-nav__trigger"
        type="button"
        aria-pressed="false"
        aria-label="Pantalla completa"
        title="Pantalla completa (F)"
      >
        <svg class="nav-icon icon-enter" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M8 3H5a2 2 0 0 0-2 2v3" />
          <path d="M16 3h3a2 2 0 0 1 2 2v3" />
          <path d="M8 21H5a2 2 0 0 1-2-2v-3" />
          <path d="M16 21h3a2 2 0 0 0 2-2v-3" />
        </svg>
        <svg class="nav-icon icon-exit" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M8 3v3a2 2 0 0 1-2 2H3" />
          <path d="M21 8h-3a2 2 0 0 1-2-2V3" />
          <path d="M3 16h3a2 2 0 0 1 2 2v3" />
          <path d="M16 21v-3a2 2 0 0 1 2-2h3" />
        </svg>
      </button>
    </nav>

    {/* Filtro SVG del Liquid Glass: feTurbulence de baja frecuencia -> feDisplacementMap
        refracta (curva) el fondo bajo el cristal, no solo lo desenfoca. Debe estar en
        el DOM (no display:none) para que backdrop-filter: url(#liquid-glass) lo use. */}
    <svg class="deck-nav__defs" width="0" height="0" aria-hidden="true" focusable="false">
      <filter id="liquid-glass" x="-40%" y="-40%" width="180%" height="180%" color-interpolation-filters="sRGB">
        <feTurbulence type="fractalNoise" baseFrequency="0.005 0.011" numOctaves="2" seed="42" result="noise" />
        <feGaussianBlur in="noise" stdDeviation="1.3" result="noiseSoft" />
        <feDisplacementMap in="SourceGraphic" in2="noiseSoft" scale="34" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </svg>

    <style>
      /* Control "Liquid Glass": UNA pieza de cristal que agrupa los botones JUNTOS.
         La REFRACCION del fondo la da el filtro SVG (#liquid-glass) encadenado en el
         backdrop-filter (no solo blur). Sin separador: cada boton se distingue por el
         circulo de hover. Por defecto solo pantalla completa; al hover/foco crece y
         revela Inicio. */
      .deck-nav__defs {
        position: absolute;
        width: 0;
        height: 0;
        overflow: hidden;
        pointer-events: none;
      }
      .deck-nav {
        position: fixed;
        top: 18px;
        right: 18px;
        z-index: 60;
        display: inline-flex;
        align-items: center;
        overflow: hidden;
        border-radius: 999px;
        background: color-mix(in srgb, var(--bg-b, #e2e8f1) 32%, transparent);
        /* Borde de cristal: hairline claro (specular del canto). */
        border: 1px solid color-mix(in srgb, #fff 22%, transparent);
        /* Base (todos los navegadores): cristal esmerilado. */
        -webkit-backdrop-filter: blur(12px) saturate(1.8);
        backdrop-filter: blur(12px) saturate(1.8);
        /* Mejora (Chromium): refraccion liquida via filtro SVG + brillo. */
        -webkit-backdrop-filter: url(#liquid-glass) blur(7px) saturate(1.8) brightness(1.06);
        backdrop-filter: url(#liquid-glass) blur(7px) saturate(1.8) brightness(1.06);
        /* Profundidad/specular: sombra + brillo superior + canto inferior + aro. */
        box-shadow:
          0 14px 38px -14px rgba(0, 0, 0, 0.6),
          inset 0 1px 1px rgba(255, 255, 255, 0.6),
          inset 0 -10px 14px -12px rgba(255, 255, 255, 0.22),
          inset 0 0 0 1px rgba(255, 255, 255, 0.08);
        opacity: 0.62;
        transition: opacity 0.2s ease;
      }
      .deck-nav:hover,
      .deck-nav:focus-within {
        opacity: 1;
      }
      /* Reflejo especular: banda brillante superior + leve canto inferior. */
      .deck-nav::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        border-radius: inherit;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0) 38%),
          linear-gradient(0deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0) 28%);
      }

      /* Segmentos transparentes (dejan ver el cristal). Sin radio ni borde propio y
         SIN separador: el contenedor recorta los extremos a la pildora. */
      .deck-nav__btn {
        position: relative;
        z-index: 1;
        flex: none;
        box-sizing: border-box;
        display: grid;
        place-items: center;
        width: 46px;
        height: 46px;
        margin: 0;
        padding: 0;
        color: var(--ink, #1b2638);
        background: transparent;
        border: 0;
        cursor: pointer;
        transition: color 0.16s ease;
      }
      /* Hover/foco: pinta un CIRCULO completo centrado tras el icono (estilo macOS). */
      .deck-nav__btn::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: color-mix(in srgb, var(--ink, #1b2638) 15%, transparent);
        transform: translate(-50%, -50%) scale(0.6);
        opacity: 0;
        pointer-events: none;
        z-index: 0;
        transition:
          opacity 0.16s ease,
          transform 0.2s cubic-bezier(0.34, 1.5, 0.5, 1);
      }
      .deck-nav__btn:hover::after,
      .deck-nav__btn:focus-visible::after {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }
      .deck-nav__btn:active::after {
        background: color-mix(in srgb, var(--accent, #2a5298) 28%, transparent);
      }
      .deck-nav__btn:hover,
      .deck-nav__btn:focus-visible {
        color: var(--accent, #2a5298);
        outline: none;
      }
      .deck-nav__btn .nav-icon {
        position: relative;
        z-index: 1;
        display: block;
        pointer-events: none;
      }

      /* Inicio: segmento colapsable a la izquierda (sin separador). Ancho 0 y oculto
         por defecto; al hover/foco crece hacia la izquierda. */
      .deck-nav__item {
        width: 0;
        opacity: 0;
        visibility: hidden;
        overflow: hidden;
        pointer-events: none;
        transition:
          width 0.3s cubic-bezier(0.34, 1.4, 0.5, 1),
          opacity 0.22s ease,
          visibility 0s linear 0.32s;
      }
      .deck-nav:hover .deck-nav__item,
      .deck-nav:focus-within .deck-nav__item {
        width: 46px;
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transition:
          width 0.3s cubic-bezier(0.34, 1.4, 0.5, 1),
          opacity 0.22s ease,
          visibility 0s linear 0s;
      }

      /* Icono de pantalla completa: "ampliar" por defecto, "reducir" en fullscreen. */
      #fs-toggle .icon-exit {
        display: none;
      }
      #fs-toggle.is-fullscreen .icon-enter {
        display: none;
      }
      #fs-toggle.is-fullscreen .icon-exit {
        display: block;
      }

      .deck-nav[hidden] {
        display: none;
      }
      /* Respeta la preferencia de menos movimiento. */
      @media (prefers-reduced-motion: reduce) {
        .deck-nav__item,
        .deck-nav__btn::after {
          transition-duration: 0.01ms !important;
        }
      }
      /* Fuera de la exportacion a PDF (?print-pdf). */
      @media print {
        .deck-nav {
          display: none !important;
        }
      }
    </style>

    <script>
      import Reveal from 'reveal.js';
      import Notes from 'reveal.js/plugin/notes';
      import Search from 'reveal.js/plugin/search';
      import Zoom from 'reveal.js/plugin/zoom';

      // --- Pantalla completa: boton flotante + tecla F como toggle ----------
      // reveal.js trae F, pero solo para ENTRAR (se sale con Esc). Aqui F
      // alterna entrar/salir y comparte logica con el boton.
      const fsRoot = document.documentElement;
      const requestFs = fsRoot.requestFullscreen || fsRoot.webkitRequestFullscreen;

      function isFullscreen() {
        return !!(document.fullscreenElement || document.webkitFullscreenElement);
      }
      function toggleFullscreen() {
        if (isFullscreen()) {
          const exit = document.exitFullscreen || document.webkitExitFullscreen;
          exit?.call(document);
        } else {
          requestFs?.call(fsRoot);
        }
      }

      const deck = new Reveal({
        plugins: [Notes, Search, Zoom],

        // Lienzo logico: el contenido se escala a cualquier pantalla.
        width: 1280,
        height: 720,
        margin: 0.06,
        minScale: 0.2,
        maxScale: 2.0,

        hash: true, // la URL refleja la diapositiva (deep-linking)
        autoSlide: 0, // sin auto-avance: el ponente controla el ritmo
        loop: false,
        slideNumber: false,
        controls: false, // sin flechas en pantalla: navegacion solo por teclado
        progress: true,
        center: true,
        transition: 'fade', // none | fade | slide | convex | concave | zoom
        backgroundTransition: 'fade',
        overview: true,

        // Sobrescribe la F nativa (solo entra) por un toggle entrar/salir.
        keyboard: {
          70: () => toggleFullscreen(), // 70 = tecla F
        },
      });

      deck.initialize();

      // --- Item de pantalla completa: mismo toggle que la tecla F -----------
      // El despliegue del menu (hover/foco) lo maneja el CSS; aqui solo la
      // accion de fullscreen y la sincronizacion del icono/estado.
      const fsBtn = document.getElementById('fs-toggle');
      if (fsBtn && requestFs) {
        fsBtn.addEventListener('click', () => {
          toggleFullscreen();
          // Suelta el foco para que el menu se repliegue tras la accion y para
          // que Espacio/Enter no reactiven el boton en vez de avanzar slide.
          fsBtn.blur();
        });
        const sync = () => {
          const on = isFullscreen();
          fsBtn.classList.toggle('is-fullscreen', on);
          fsBtn.setAttribute('aria-pressed', String(on));
          fsBtn.setAttribute(
            'title',
            on ? 'Salir de pantalla completa (F)' : 'Pantalla completa (F)',
          );
        };
        document.addEventListener('fullscreenchange', sync);
        document.addEventListener('webkitfullscreenchange', sync);
      } else if (fsBtn) {
        // Navegador sin Fullscreen API (p. ej. iPhone): ocultar solo este item.
        fsBtn.hidden = true;
      }
    </script>
  </body>
</html>
