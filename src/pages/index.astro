---
// Galeria / home: lista todas las presentaciones agrupadas por categoria.
// Se autogenera desde la coleccion: anadir una carpeta de deck la hace aparecer.
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import 'augmented-ui/augmented-ui.min.css';
import '@fontsource-variable/jetbrains-mono';

const title = 'Presentaciones';

const decks = (await getCollection('decks', (d) => !d.data.draft)).sort(
  (a, b) => (b.data.pubDate?.getTime() ?? 0) - (a.data.pubDate?.getTime() ?? 0),
);

// Agrupar por categoria (campo de frontmatter, no por carpeta en disco).
const byCategory = new Map<string, typeof decks>();
for (const deck of decks) {
  const cat = deck.data.category;
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(deck);
}
const categories = [...byCategory.keys()].sort((a, b) => a.localeCompare(b, 'es'));

---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <main>
      <header class="masthead">
        <h1>{title}<span class="caret">_</span></h1>
      </header>

      {
        categories.map((cat) => (
          <section class="group">
            <h2 class="group-title">{cat}</h2>
            <ul class="grid">
              {byCategory.get(cat)!.map((deck) => (
                <li>
                  <a class="card" href={`/decks/${deck.id}`}>
                    <div
                      class="thumb"
                      data-augmented-ui="tl-clip tr-step br-clip bl-clip border"
                    >
                      {deck.data.cover ? (
                        <Image
                          src={deck.data.cover}
                          alt={deck.data.coverAlt}
                          widths={[160, 320]}
                          sizes="160px"
                        />
                      ) : (
                        <span class="ph">&gt;_</span>
                      )}
                    </div>
                    <div class="meta">
                      <h3>{deck.data.title}</h3>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </main>

    <style>
      :root {
        --bg-0: #07090c;
        --bg-1: #0b0e13;
        --ink: #e6edf3;
        --ink-dim: #7d8590;
        --line: #1c2230;
        --accent: #3fb950;
        --font: 'JetBrains Mono Variable', ui-monospace, 'SF Mono', Menlo,
          Consolas, monospace;
      }
      html {
        /* Negro terminal + rejilla muy sutil + halo verde frio. */
        background:
          radial-gradient(60% 50% at 12% 0%, rgba(63, 185, 80, 0.08), transparent 70%),
          repeating-linear-gradient(0deg, transparent 0 31px, rgba(125, 133, 144, 0.04) 31px 32px),
          repeating-linear-gradient(90deg, transparent 0 31px, rgba(125, 133, 144, 0.04) 31px 32px),
          var(--bg-0);
        min-height: 100%;
      }
      body {
        margin: 0;
        color: var(--ink);
        font-family: var(--font);
        font-weight: 400;
      }
      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 2rem) 4rem;
      }
      .masthead h1 {
        font-weight: 700;
        font-size: clamp(1.4rem, 3vw, 1.9rem);
        letter-spacing: 0;
        margin: 0;
        color: var(--ink);
      }
      .caret {
        color: var(--accent);
        animation: blink 1.1s steps(1) infinite;
      }
      @keyframes blink {
        50% { opacity: 0; }
      }
      .group {
        margin-top: clamp(1.5rem, 3vw, 2.25rem);
      }
      .group-title {
        font-weight: 700;
        font-size: 0.72rem;
        color: var(--ink-dim);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin: 0 0 0.85rem;
      }
      .group-title::before {
        content: '// ';
        color: var(--accent);
      }
      .grid {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: clamp(0.65rem, 1.3vw, 1rem);
      }
      .card {
        display: block;
        text-decoration: none;
        color: inherit;
      }
      /* Borde HUD via augmented-ui: misma familia que las diapositivas
         (chaflanes + hombro escalonado sup-der), borde que sigue la silueta. */
      .thumb {
        position: relative;
        aspect-ratio: 16 / 10;
        --aug-border-bg: rgba(230, 237, 243, 0.55);
        --aug-border-all: 1.5px;
        --aug-tl: 8px;
        --aug-tr: 18px;
        --aug-tr-inset1: 15px;
        --aug-br: 13px;
        --aug-bl: 13px;
        transition: transform 0.16s ease;
      }
      .thumb :global(img),
      .ph {
        position: absolute;
        inset: 0;
        z-index: 0;
        width: 100%;
        height: 100%;
      }
      .thumb :global(img) {
        object-fit: cover;
        display: block;
        filter: saturate(0.85) brightness(0.92);
      }
      .ph {
        display: grid;
        place-items: center;
        background: var(--bg-1);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--accent);
      }
      .card:hover .thumb,
      .card:focus-visible .thumb {
        transform: translateY(-2px);
        --aug-border-bg: var(--accent);
      }
      .meta {
        padding: 0.45rem 0.1rem 0;
      }
      .meta h3 {
        font-weight: 500;
        font-size: 0.74rem;
        line-height: 1.3;
        margin: 0;
        color: var(--ink);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
    </style>
  </body>
</html>
