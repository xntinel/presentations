---
// Single dynamic route that renders ANY deck in the collection.
// reveal.js is a global singleton -> one deck per route/page.
import { getCollection, render } from 'astro:content';
import RevealLayout from '@layouts/RevealLayout.astro';

export async function getStaticPaths() {
  // Query the collection ONCE here (doing it per page would be a performance
  // footgun: Astro re-scans the images of every entry).
  const decks = await getCollection('decks', (d) => !d.data.draft);
  return decks.map((deck) => ({ params: { slug: deck.id }, props: { deck } }));
}

const { deck } = Astro.props;
// Pre-render the MDX/MD body to HTML at build time (we do not use reveal's
// client-side Markdown plugin): static output, compatible with Astro islands.
const { Content } = await render(deck);
---

<RevealLayout title={deck.data.title} theme={deck.data.theme}>
  <Content />
</RevealLayout>
