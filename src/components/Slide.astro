---
// Diapositiva imagen + titulo para decks MDX.
// Reproduce la plantilla .shot/.frame/header estilizada en themes/_base.css.
//
// Uso en MDX:
//   <Slide img={cover} cover eager note={`Notas del ponente...`}>
//     <h1>Titulo</h1>
//   </Slide>
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  img: ImageMetadata;
  cover?: boolean;
  eager?: boolean;
  note?: string;
}

const { img, cover = false, eager = false, note } = Astro.props;
---

<section class={cover ? 'cover' : undefined}>
  <div class="shot">
    <div class="frame">
      <Image
        src={img}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        loading={eager ? 'eager' : 'lazy'}
      />
      <header>
        <slot />
      </header>
    </div>
  </div>
  {note && <aside class="notes" set:html={note} />}
</section>
